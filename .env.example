# hara-control — copy to .env and fill in. NEVER commit .env.

# ── LiteLLM proxy (data plane) ──────────────────────────────────────────────
# Master key the control plane uses to talk to LiteLLM admin API.
LITELLM_MASTER_KEY=sk-hara-master-dev-change-me

# ── Upstream provider (gateway → real model) ────────────────────────────────
# The real DeepSeek provider key stays server-side. Devices receive scoped, revocable LiteLLM
# virtual keys. Formal production also imports an envelope-encrypted source-of-truth copy.
UPSTREAM_API_KEY=

# ── Phase-0 spike (mock upstream — no real key needed) ──────────────────────
MOCK_UPSTREAM_PORT=8899
LITELLM_PORT=4000

# ── Control-plane DB (Phase 1+) ─────────────────────────────────────────────
DATABASE_URL=postgresql://hara:hara@localhost:5433/hara_control?schema=public
# LiteLLM must never initialize against Hara Control's public schema.
LITELLM_DATABASE_URL=postgresql://hara:hara@localhost:5433/hara_control?schema=litellm

# ── Control plane (NestJS) ──────────────────────────────────────────────────
PORT=4100
# admin API key (header x-admin-key) — gates /admin/*. Phase 2 swaps for OIDC/RBAC.
HARA_CONTROL_ADMIN_KEY=admin-dev-change-me
# JWT signing secret must be independent in production (the production preflight rejects reuse).
HARA_JWT_SECRET=jwt-dev-change-me
# data-plane adapter: "litellm" in prod, anything else (or unset) = in-process mock for dev/test
GATEWAY_ADAPTER=mock
LITELLM_URL=http://localhost:4000
HARA_ALLOWED_MODELS=deepseek-chat,deepseek-pro
HARA_DEFAULT_MODEL=deepseek-chat

# ── Security hardening (see HARDENING.md) ───────────────────────────────────
# SSRF allow-list for OUTBOUND fetches (LiteLLM + embeddings upstreams). Link-local/metadata
# (169.254.0.0/16) is always blocked. Comma-separated hostnames; empty = allow-list off. Explicitly
# allow loopback for the normal same-host LiteLLM deployment.
HARA_SSRF_ALLOW_HOSTS=
# When no allow-list is set, also refuse RFC1918/loopback upstreams (1 = on). Default off so the normal
# single-box LiteLLM-at-localhost deployment keeps working; turn on for hardened/multi-host setups.
HARA_SSRF_BLOCK_PRIVATE=0
# Max redirect hops to follow while re-validating each Location against the SSRF policy.
HARA_SSRF_MAX_REDIRECTS=5

# Device-token TTL (minutes). Every issued device token expires; the device re-enrolls. Default 7 days.
HARA_DEVICE_TOKEN_TTL_MINUTES=10080
# Per-device spend cap (USD). 0 = uncapped. Enforced only once a live-spend checker is wired (hook).
HARA_DEVICE_SPEND_CAP_USD=0

# ── At-rest secret envelope encryption / KMS (HARDENING.md §B) ──────────────────────────────
# SecretsService envelope-encrypts secrets (per-secret AES-256-GCM DEK, wrapped by a master CEK).
# Provider selects the root-key custodian. "local" (default) keeps the root key on this box; aws/gcp/
# vault are documented seams that throw until implemented.
HARA_KMS_PROVIDER=local
# LOCAL provider master key (the CEK that wraps every per-secret DEK). Exactly 32 bytes as base64,
# base64url, or 64-char hex. Generate one with:  openssl rand -base64 32
# REQUIRED before SecretsService can encrypt/decrypt under the local provider. NEVER commit a real key.
HARA_KMS_MASTER_KEY=
# Production preference: an owner-only regular file (not a symlink).
# HARA_KMS_KEYFILE=/etc/hara-control/kms-master.key
