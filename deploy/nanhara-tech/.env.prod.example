# hara-control production example — copy to .env, fill secrets, then chmod 600 .env.
# NEVER commit the filled .env. The production deploy scripts reject symlinks, broad permissions,
# duplicated secrets and shell syntax; they parse NAME=value without sourcing/executing the file.

# Runtime.
NODE_ENV=production
DEPLOY_MODE=self

# Nest control plane. Bind to localhost; nginx terminates TLS and proxies in. (Aliyun security group
# is the backstop — do NOT open 4100 publicly.)
PORT=4100
HOST=127.0.0.1
# Back-compat break-glass key for /admin/*. Use a distinct value from the JWT signing secret.
HARA_CONTROL_ADMIN_KEY=__SET_A_STRONG_RANDOM__
HARA_JWT_SECRET=__SET_A_DIFFERENT_STRONG_RANDOM__

# Envelope-encryption root. Store 32 random bytes as base64 in an owner-only, non-symlink keyfile:
#   umask 077; openssl rand -base64 32 > /etc/hara-control/kms-master.key
HARA_KMS_PROVIDER=local
HARA_KMS_KEYFILE=/etc/hara-control/kms-master.key

# Control-plane DB. Production RDS; keep the credential owner-only in the real .env.
DATABASE_URL=postgresql://hara:__SET_DB_PASSWORD__@pgm-bp1u983bh545l9f2to.pg.rds.aliyuncs.com:5432/hara_db?schema=public
# Same database is allowed, but LiteLLM must use its own isolated schema.
LITELLM_DATABASE_URL=postgresql://hara:__SET_DB_PASSWORD__@pgm-bp1u983bh545l9f2to.pg.rds.aliyuncs.com:5432/hara_db?schema=litellm

# Formal managed AI: devices receive revocable LiteLLM virtual keys. UPSTREAM_API_KEY is a one-time
# bootstrap input: the first verified deploy imports it into envelope-encrypted storage and atomically
# blanks this line. Later rotations happen in the SUPERADMIN console and activate on controlled deploy.
GATEWAY_ADAPTER=litellm
LITELLM_URL=http://127.0.0.1:4000
LITELLM_MASTER_KEY=__SET_A_DISTINCT_STRONG_RANDOM__
HARA_ALLOWED_MODELS=deepseek-v4-flash,deepseek-v4-pro
HARA_DEFAULT_MODEL=deepseek-v4-flash
UPSTREAM_API_KEY=__SET_DEEPSEEK_PAYG_KEY__

# The private loopback gateway is intentionally allow-listed for hara-control's SSRF guard.
HARA_SSRF_ALLOW_HOSTS=127.0.0.1
