# hara-control — copy to .env and fill in. NEVER commit .env.

# ── LiteLLM proxy (data plane) ──────────────────────────────────────────────
# Master key the control plane uses to talk to LiteLLM admin API.
LITELLM_MASTER_KEY=sk-hara-master-dev-change-me

# ── Upstream provider (gateway → real model) ────────────────────────────────
# The REAL provider key lives ONLY here, never on a device.
#
# ⚠️  Do NOT use a coding-plan key (sk-sp-...). Those are for coding tools only.
#     Use a regular pay-as-you-go DashScope API key against the compatible-mode
#     endpoint (https://dashscope.aliyuncs.com/compatible-mode/v1), or any other
#     OpenAI-compatible upstream.
UPSTREAM_API_KEY=
UPSTREAM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
UPSTREAM_MODEL=qwen-plus

# ── Phase-0 spike (mock upstream — no real key needed) ──────────────────────
MOCK_UPSTREAM_PORT=8899
LITELLM_PORT=4000

# ── Control-plane DB (Phase 1+) ─────────────────────────────────────────────
DATABASE_URL=postgresql://hara:hara@localhost:5433/hara_control?schema=public

# ── Control plane (NestJS) ──────────────────────────────────────────────────
PORT=4100
# admin API key (header x-admin-key) — gates /admin/*. Phase 2 swaps for OIDC/RBAC.
HARA_CONTROL_ADMIN_KEY=admin-dev-change-me
# data-plane adapter: "litellm" in prod, anything else (or unset) = in-process mock for dev/test
GATEWAY_ADAPTER=mock
LITELLM_URL=http://localhost:4000

# ── Security hardening (see HARDENING.md) ───────────────────────────────────
# SSRF allow-list for OUTBOUND fetches (LiteLLM + embeddings upstreams). Link-local/metadata
# (169.254.0.0/16) and loopback are ALWAYS blocked. Comma-separated hostnames; empty = allow-list off.
HARA_SSRF_ALLOW_HOSTS=
# When no allow-list is set, also refuse RFC1918/loopback upstreams (1 = on). Default off so the normal
# single-box LiteLLM-at-localhost deployment keeps working; turn on for hardened/multi-host setups.
HARA_SSRF_BLOCK_PRIVATE=0
# Max redirect hops to follow while re-validating each Location against the SSRF policy.
HARA_SSRF_MAX_REDIRECTS=5

# Device-token TTL (minutes). Every issued device token expires; the device re-enrolls. Default 7 days.
HARA_DEVICE_TOKEN_TTL_MINUTES=10080
# Per-device spend cap (USD). 0 = uncapped. Enforced only once a live-spend checker is wired (hook).
HARA_DEVICE_SPEND_CAP_USD=0
