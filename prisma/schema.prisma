// hara-control data model. PostgreSQL (shared with the LiteLLM data plane so the fleet
// usage view can JOIN device records against LiteLLM's spend tables — no cross-DB ETL).
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector] // pgvector — org-asset semantic search (P0)
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  policy    Json     @default("{}") // org-level governance: modelDeny / requireApprovalForWrites / toolDeny / budget
  createdAt DateTime @default(now())

  enrollCodes      EnrollCode[]
  devices          Device[]
  auditLogs        AuditLog[]
  roles            Role[]
  teams            Team[]
  persons          Person[]
  digitalEmployees DigitalEmployee[]
  assets           Asset[]
}

/// One-time enrollment code an admin hands to a machine. Exchanged at POST /v1/enroll.
model EnrollCode {
  id        String    @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  code      String    @unique
  model     String    @default("") // model alias the gateway routes this device to
  baseUrl   String?               // explicit OpenAI-compatible base; else <gateway>/v1
  expiresAt DateTime
  usedAt    DateTime?             // single-use: set when redeemed
  createdAt DateTime  @default(now())

  // per-person enroll: binds the enrolled device to a Person so it inherits that person's
  // digital-employee assignments from the first heartbeat (authoritative binding).
  person   Person? @relation(fields: [personId], references: [id])
  personId String?

  device Device?

  @@index([orgId])
}

model Device {
  id          String   @id @default(uuid())
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  name        String
  os          String   @default("")
  haraVersion String   @default("")
  enrolledAt  DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  roleVersion Int      @default(0) // watermark: bumped when this device's resolved role bundle changes

  enrollCode   EnrollCode? @relation(fields: [enrollCodeId], references: [id])
  enrollCodeId String?     @unique

  person   Person? @relation(fields: [personId], references: [id])
  personId String?

  tokens DeviceToken[]

  @@index([orgId])
  @@index([personId])
}

/// A scoped, revocable device token. The token value itself is a gateway (LiteLLM) virtual
/// key minted via the GatewayAdapter; we store only its hash (for heartbeat auth lookup) and
/// the gateway key id (for revoke). The real provider key never lives on the device or here.
model DeviceToken {
  id           String    @id @default(uuid())
  device       Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId     String
  tokenHash    String    @unique // sha256 of the issued token
  gatewayKeyId String              // id returned by the gateway adapter, used to revoke
  model        String    @default("")
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  @@index([deviceId])
}

/// Append-only audit trail. payload is JSONB (policy/context), queryable in Postgres.
model AuditLog {
  id        String   @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  action    String   // e.g. "enroll", "revoke", "enroll_code.create"
  actorType String   // "admin" | "device" | "system"
  actorId   String   @default("")
  payload   Json     @default("{}")
  at        DateTime @default(now())

  @@index([orgId, at])
}

// ── B3: agent / digital-employee / role-assignment governance ──────────────────────────────

/// Org-defined reusable persona — the control-plane authority for a CLI Role
/// (mirrors hara-cli src/org/roles.ts: key/description/owns/rejects/model/allowTools/denyTools/system).
/// This is the "job description" template; a DigitalEmployee is an instance of it bound to a principal.
model Role {
  id          String       @id @default(uuid())
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  key         String // the role id the CLI sees as `name` in frontmatter (e.g. "reviewer")
  description String       @default("")
  owns        String[]     @default([]) // routing OWN keywords
  rejects     String[]     @default([]) // routing REJECT keywords
  model       String? // optional model override (subject to org/team model allow-list)
  allowTools  String[]     @default([])
  denyTools   String[]     @default([])
  system      String       @default("") // persona/system body (markdown)
  version     Int          @default(1) // bumped on edit → drives device resync
  archivedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  assignments DigitalEmployee[]

  @@unique([orgId, key])
  @@index([orgId])
}

model Team {
  id        String       @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  name      String
  policy    Json         @default("{}") // team governance: modelDeny / requireApprovalForWrites / toolDeny / budget
  createdAt DateTime     @default(now())

  members     PersonTeam[]
  assignments DigitalEmployee[]
  assets      Asset[]

  @@unique([orgId, name])
  @@index([orgId])
}

model Person {
  id        String       @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  email     String // becomes the OIDC subject in Phase 2
  name      String       @default("")
  createdAt DateTime     @default(now())

  teams       PersonTeam[]
  devices     Device[]
  enrollCodes EnrollCode[]
  assignments DigitalEmployee[]

  @@unique([orgId, email])
  @@index([orgId])
}

model PersonTeam {
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId String
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId   String

  @@id([personId, teamId])
}

/// A "digital employee" = a Role instance granted to a Person and/or Team. The unit the admin
/// counts ("who has which agents"). Resolution: a device's Person + their Teams' grants → role set.
model DigitalEmployee {
  id        String       @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  role      Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId    String
  person    Person?      @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId  String?
  team      Team?        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    String?
  name      String       @default("") // display name, e.g. "Payments Reviewer"
  status    String       @default("active") // active | suspended
  policy    Json         @default("{}") // per-assignment overrides (merges over org < team < assignment)
  createdAt DateTime     @default(now())

  @@index([orgId])
  @@index([roleId])
  @@index([personId])
  @@index([teamId])
}

// ── B2: multi-dimensional code-asset / knowledge management ────────────────────────────────

// project stays device-only and is never uploaded; PERSONAL..PUBLIC are the server-side scopes
enum AssetScope {
  PERSONAL
  TEAM
  ORG
  PUBLIC
}

enum AssetKind {
  SKILL
  SNIPPET
  PLAYBOOK
  CONVENTION
}

enum AssetLifecycle {
  DRAFT
  IN_REVIEW
  PUBLISHED
  DEPRECATED
}

enum TrustTier {
  ORG_VERIFIED
  ORG
  COMMUNITY
  UNVERIFIED
}

enum AssetOrigin {
  AUTHORED
  PROMOTED
  IMPORTED
}

/// A unit of shared org knowledge (skill/snippet/playbook). Stable identity + the dimensions;
/// the current markdown lives in the latest AssetVersion. Markdown-as-SSOT, same as the CLI.
model Asset {
  id        String         @id @default(uuid())
  org       Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  team      Team?          @relation(fields: [teamId], references: [id])
  teamId    String? // null = org-wide; set = team-scoped
  ownerDeviceId String? // provenance: which device captured it (Person identity is Phase-2b)
  scope     AssetScope // ── dimension: visibility / egress spine
  kind      AssetKind // ── dimension: routing spine
  lifecycle AssetLifecycle @default(DRAFT)
  trustTier TrustTier      @default(ORG)
  origin    AssetOrigin    @default(AUTHORED)
  slug      String // kebab id; the skill `name` for SKILLs
  title     String         @default("")
  lang      String?
  tags      String[]       @default([])
  sourceUrl String? // provenance for IMPORTED
  promotedFromId String? // the asset this was copied-forward from on a scope promotion
  supersededById String?
  searchText String        @default("") // denormalized lexical haystack (title+tags+lang+published body)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  versions AssetVersion[]

  @@unique([orgId, scope, teamId, kind, slug])
  @@index([orgId, scope, lifecycle])
  @@index([orgId, kind])
}

/// Immutable content version — the markdown SSOT. Publishing a change appends a row.
model AssetVersion {
  id              String   @id @default(uuid())
  asset           Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetId         String
  body            String // the byte-exact markdown (frontmatter + content)
  contentHash     String // sha256(body) — dedup + sync etag
  redactions      String[] @default([]) // what the guard stripped on contribute (audit)
  createdByDeviceId String?
  createdAt       DateTime @default(now())
  // semantic search (P0). dim is unbounded so the embedding model is configurable (local/remote);
  // {embedModel,embedDim} track which model produced it so search only compares like-for-like.
  embedding       Unsupported("vector")?
  embedModel      String?
  embedDim        Int?

  @@index([assetId, createdAt])
  @@index([contentHash])
}
