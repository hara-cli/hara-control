# hara-control reverse proxy (Caddy) — auto-TLS, easiest for small teams.
# Replace cp.example.com. See docs/selfhost.md §③. Caddy issues + renews the cert itself.
#
# Same routing as the nginx example: chat -> LiteLLM(4000), control -> hara-control(4100),
# /admin locked. Caddy matches most-specific path first, so /v1/chat* wins over /v1/*.

cp.example.com {
    # data plane: chat to LiteLLM
    @chat path /v1/chat* /v1/messages /v1/models
    handle @chat {
        reverse_proxy 127.0.0.1:4000
    }

    # admin: NEVER public — allow only loopback / your office IP
    @admin path /admin/*
    handle @admin {
        @allowed remote_ip 127.0.0.1 <YOUR_OFFICE_IP>
        handle @allowed { reverse_proxy 127.0.0.1:4100 }
        respond 403
    }

    # control plane: enroll / heartbeat / roles
    handle /v1/* {
        reverse_proxy 127.0.0.1:4100
    }

    respond 404
}
