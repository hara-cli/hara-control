// hara-control data model. PostgreSQL (shared with the LiteLLM data plane so the fleet
// usage view can JOIN device records against LiteLLM's spend tables — no cross-DB ETL).
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector] // pgvector — org-asset semantic search (P0)
}

/// Admin console role. SUPERADMIN ≥ ADMIN ≥ MEMBER (see src/common/admin-auth.guard.ts). The shared
/// x-admin-key (back-compat) is treated as SUPERADMIN. MEMBER is the future "self-only" role tier.
enum AdminRole {
  SUPERADMIN
  ADMIN
  MEMBER
}

/// Built-in admin console account (Phase 1 of docs/AUTH_SPEC.md). Password is scrypt-hashed via
/// src/common/crypto.ts. `disabledAt` is the stateless revoke: checked on every login + every
/// guard pass. `totpSecret` is a deliberate forward-seam — unused in v1 so optional TOTP can be
/// added later without a migration. `orgId` is nullable: SUPERADMINs are typically org-less; ADMIN
/// MEMBER accounts are org-scoped in later phases. NOT FK'd to Organization yet — table is created
/// via `prisma db push` at deploy time and orgs are managed independently of admin accounts.
model AdminUser {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         AdminRole  @default(ADMIN)
  orgId        String?
  disabledAt   DateTime?
  totpSecret   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

/// Org-unit type for the self-referential hierarchy. A single company = one COMPANY node with
/// DEPARTMENT children (no GROUP parent). A group/conglomerate adds a GROUP root over COMPANY nodes.
/// TEAM is the leaf tier (the standalone `Team` model is NOT folded in yet — see docs/org-hierarchy.md).
enum OrgUnitType {
  GROUP // 集团
  COMPANY // 公司
  DEPARTMENT // 部门
  TEAM // 组
}

/// An org unit — a node in a typed, self-referential tree (集团 → 公司 → 部门 → 组). Pre-existing rows
/// default to COMPANY roots (parentId null), so single-company mode keeps working unchanged. Governance
/// (`policy`) inherits DOWN the tree: a department inherits its company's setting unless it overrides
/// (see OrgTreeService.resolveInherited). Self-relation name "OrgTree": parent ↔ children.
model Organization {
  id        String      @id @default(uuid())
  name      String
  type      OrgUnitType @default(COMPANY) // 集团/公司/部门/组 — advisory nesting, not hard-enforced
  parentId  String? // null = a root unit (a standalone COMPANY, or a GROUP top); set = a child unit
  policy    Json        @default("{}") // governance: modelDeny / requireApprovalForWrites / toolDeny / budget
  createdAt DateTime    @default(now())

  // self-referential tree (downward inheritance walks parent → … → root)
  parent   Organization?  @relation("OrgTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Organization[] @relation("OrgTree")

  enrollCodes      EnrollCode[]
  devices          Device[]
  auditLogs        AuditLog[]
  roles            Role[]
  teams            Team[]
  persons          Person[]
  digitalEmployees DigitalEmployee[]
  assets           Asset[]
  workSessions     WorkSession[]
  workEvents       WorkEvent[]

  @@index([parentId])
}

/// One-time enrollment code an admin hands to a machine. Exchanged at POST /v1/enroll.
model EnrollCode {
  id        String    @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  code      String    @unique
  model     String    @default("") // model alias the gateway routes this device to
  baseUrl   String?               // explicit OpenAI-compatible base; else <gateway>/v1
  expiresAt DateTime
  usedAt    DateTime?             // single-use: set when redeemed
  createdAt DateTime  @default(now())
  tokenTtlMinutes Int?            // lifetime of the issued internal key; null keeps the operator default
  budgetLimits    Json      @default("[]") // rolling 5h / 7d / 30d USD windows, validated by the control plane
  rpmLimit        Int?            // optional data-plane requests-per-minute ceiling
  tpmLimit        Int?            // optional data-plane tokens-per-minute ceiling

  // per-person enroll: binds the enrolled device to a Person so it inherits that person's
  // digital-employee assignments from the first heartbeat (authoritative binding).
  person   Person? @relation(fields: [personId], references: [id])
  personId String?

  device Device?

  @@index([orgId])
}

model Device {
  id          String   @id @default(uuid())
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  name        String
  os          String   @default("")
  haraVersion String   @default("")
  enrolledAt  DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  roleVersion Int      @default(0) // watermark: bumped when this device's resolved role bundle changes

  enrollCode   EnrollCode? @relation(fields: [enrollCodeId], references: [id])
  enrollCodeId String?     @unique

  person   Person? @relation(fields: [personId], references: [id])
  personId String?

  tokens       DeviceToken[]
  workSessions WorkSession[]

  @@index([orgId])
  @@index([personId])
}

/// A scoped, revocable device token. The token value itself is a gateway (LiteLLM) virtual
/// key minted via the GatewayAdapter; we store only its hash (for heartbeat auth lookup) and
/// the gateway key id (for revoke). The real provider key never lives on the device or here.
model DeviceToken {
  id           String    @id @default(uuid())
  device       Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId     String
  tokenHash    String    @unique // sha256 of the issued token
  gatewayKeyId String              // id returned by the gateway adapter, used to revoke
  model        String    @default("")
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?           // short-TTL discipline: tokens expire and must be re-enrolled
  revokedAt    DateTime?
  budgetLimits Json      @default("[]") // immutable policy copied from the one-time enrollment code
  rpmLimit     Int?
  tpmLimit     Int?

  @@index([deviceId])
}

/// Append-only audit trail. payload is JSONB (policy/context), queryable in Postgres.
/// Tamper-evident: each row carries the prior row's hash (per-org chain) and its own rowHash =
/// sha256(canonical(this) + prevHash). Editing/deleting any historical row breaks the chain, which
/// AuditService.verify() detects. seq is the per-org monotonic position in the chain.
model AuditLog {
  id        String   @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  action    String   // e.g. "enroll", "revoke", "enroll_code.create"
  actorType String   // "admin" | "device" | "system"
  actorId   String   @default("")
  payload   Json     @default("{}")
  at        DateTime @default(now())
  seq       Int      @default(0)  // per-org monotonic position in the hash chain
  prevHash  String   @default("") // rowHash of the previous audit row in this org's chain
  rowHash   String   @default("") // sha256(canonical(this) + prevHash) — tamper-evidence anchor

  @@index([orgId, at])
  // A unique sequence plus serializable/retried appends prevents concurrent chain forks.
  @@unique([orgId, seq])
}

/// At-rest secret store (HARDENING.md §B). Envelope-encrypted via a KmsAdapter: the plaintext is
/// encrypted under a per-secret DEK (AES-256-GCM, iv+tag packed into `ciphertext`), and that DEK is
/// wrapped under the KMS master CEK (iv+tag packed into `wrappedDek`). We store ONLY the envelope —
/// never plaintext, never an unwrapped DEK. `keyRef` identifies which CEK wrapped the DEK (rotation).
/// `orgId` is bound as the GCM AAD on the secret, so a ciphertext can't be replayed across tenants.
/// Intentionally NOT org-FK'd: a null orgId is a control-plane-global secret (e.g. the upstream key),
/// and the tenant binding is enforced cryptographically (AAD), not just relationally.
model Secret {
  id         String   @id @default(uuid())
  orgId      String?  // null = control-plane-global secret; set = tenant-scoped (also bound as AAD)
  name       String   // logical name, e.g. "upstream.api_key" / "litellm.master_key"
  ciphertext Bytes    // plaintext encrypted under the per-secret DEK (iv ‖ tag ‖ enc)
  wrappedDek Bytes    // per-secret DEK encrypted ("wrapped") under the KMS CEK (iv ‖ tag ‖ enc)
  keyRef     String   // which CEK/master key wrapped the DEK — drives rotation + multi-provider
  version    Int      @default(1) // increments on rotation; safe lifecycle identity, never key-derived
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Tenant secrets are unique here. PostgreSQL treats NULL values as distinct, so the migration
  // also creates a partial unique index on name WHERE orgId IS NULL for global secrets.
  @@unique([orgId, name])
  @@index([orgId])
}

/// Control-plane-wide security audit events that do not belong to one customer organization
/// (provider credential rotation/test, KMS maintenance, trust-root changes). Payloads must contain
/// status/intent only — never credentials, fingerprints derived from credentials, or auth headers.
model SystemAuditLog {
  id        String   @id @default(cuid())
  action    String
  actorType String
  actorId   String   @default("")
  payload   Json     @default("{}")
  at        DateTime @default(now())

  @@index([at])
  @@index([action, at])
}

/// Which non-secret credential revision a supervised provider runtime has loaded. This records only
/// Secret.version and process identity; it never stores a credential hash/fingerprint or plaintext.
model ProviderActivation {
  provider      String   @id
  secretName    String
  secretVersion Int
  runtimeId     String
  activatedAt   DateTime @default(now())

  @@index([activatedAt])
}

// ── B3: agent / digital-employee / role-assignment governance ──────────────────────────────

/// Org-defined reusable persona — the control-plane authority for a CLI Role
/// (mirrors hara-cli src/org/roles.ts: key/description/owns/rejects/model/allowTools/denyTools/system).
/// This is the "job description" template; a DigitalEmployee is an instance of it bound to a principal.
model Role {
  id          String       @id @default(uuid())
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  key         String // the role id the CLI sees as `name` in frontmatter (e.g. "reviewer")
  description String       @default("")
  owns        String[]     @default([]) // routing OWN keywords
  rejects     String[]     @default([]) // routing REJECT keywords
  model       String? // optional model override (subject to org/team model allow-list)
  allowTools  String[]     @default([])
  denyTools   String[]     @default([])
  system      String       @default("") // persona/system body (markdown)
  version     Int          @default(1) // bumped on edit → drives device resync
  archivedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  assignments DigitalEmployee[]

  @@unique([orgId, key])
  @@index([orgId])
}

model Team {
  id        String       @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  name      String
  policy    Json         @default("{}") // team governance: modelDeny / requireApprovalForWrites / toolDeny / budget
  createdAt DateTime     @default(now())

  members     PersonTeam[]
  assignments DigitalEmployee[]
  assets      Asset[]

  @@unique([orgId, name])
  @@index([orgId])
}

model Person {
  id        String       @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  email     String // becomes the OIDC subject in Phase 2
  name      String       @default("")
  createdAt DateTime     @default(now())

  teams        PersonTeam[]
  devices      Device[]
  enrollCodes  EnrollCode[]
  assignments  DigitalEmployee[]
  workSessions WorkSession[]

  @@unique([orgId, email])
  @@index([orgId])
}

model PersonTeam {
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId String
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId   String

  @@id([personId, teamId])
}

/// A "digital employee" = a Role instance granted to a Person and/or Team. The unit the admin
/// counts ("who has which agents"). Resolution: a device's Person + their Teams' grants → role set.
model DigitalEmployee {
  id        String       @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  role      Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId    String
  person    Person?      @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId  String?
  team      Team?        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    String?
  name      String       @default("") // display name, e.g. "Payments Reviewer"
  status    String       @default("active") // active | suspended
  policy    Json         @default("{}") // per-assignment overrides (merges over org < team < assignment)
  createdAt DateTime     @default(now())

  @@index([orgId])
  @@index([roleId])
  @@index([personId])
  @@index([teamId])
}

// ── B2: multi-dimensional code-asset / knowledge management ────────────────────────────────

// project stays device-only and is never uploaded; PERSONAL..PUBLIC are the server-side scopes
enum AssetScope {
  PERSONAL
  TEAM
  ORG
  PUBLIC
}

enum AssetKind {
  SKILL
  SNIPPET
  PLAYBOOK
  CONVENTION
  KNOWLEDGE // reference docs / how-tos / domain knowledge (the 知识库 facet — same store)
}

enum AssetLifecycle {
  DRAFT
  IN_REVIEW
  PUBLISHED
  DEPRECATED
}

enum TrustTier {
  ORG_VERIFIED
  ORG
  COMMUNITY
  UNVERIFIED
}

enum AssetOrigin {
  AUTHORED
  PROMOTED
  IMPORTED
}

/// A unit of shared org knowledge (skill/snippet/playbook). Stable identity + the dimensions;
/// the current markdown lives in the latest AssetVersion. Markdown-as-SSOT, same as the CLI.
model Asset {
  id        String         @id @default(uuid())
  org       Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  team      Team?          @relation(fields: [teamId], references: [id])
  teamId    String? // null = org-wide; set = team-scoped
  ownerDeviceId String? // provenance: which device captured it (Person identity is Phase-2b)
  scope     AssetScope // ── dimension: visibility / egress spine
  kind      AssetKind // ── dimension: routing spine
  lifecycle AssetLifecycle @default(DRAFT)
  trustTier TrustTier      @default(ORG)
  origin    AssetOrigin    @default(AUTHORED)
  slug      String // kebab id; the skill `name` for SKILLs
  title     String         @default("")
  summary   String? // one-line index (uniform progressive-disclosure label for every kind)
  lang      String?
  tags      String[]       @default([])
  sourceUrl String? // provenance for IMPORTED
  promotedFromId String? // the asset this was copied-forward from on a scope promotion
  supersededById String?
  searchText String        @default("") // denormalized lexical haystack (title+tags+lang+published body)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  versions AssetVersion[]

  @@unique([orgId, scope, teamId, kind, slug])
  @@index([orgId, scope, lifecycle])
  @@index([orgId, kind])
}

/// Immutable content version — the markdown SSOT. Publishing a change appends a row.
model AssetVersion {
  id              String   @id @default(uuid())
  asset           Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetId         String
  body            String // the byte-exact markdown (frontmatter + content)
  contentHash     String // sha256(body) — dedup + sync etag
  redactions      String[] @default([]) // what the guard stripped on contribute (audit)
  createdByDeviceId String?
  createdAt       DateTime @default(now())
  // semantic search (P0). dim is unbounded so the embedding model is configurable (local/remote);
  // {embedModel,embedDim} track which model produced it so search only compares like-for-like.
  embedding       Unsupported("vector")?
  embedModel      String?
  embedDim        Int?

  @@index([assetId, createdAt])
  @@index([contentHash])
}

// ── B-end work-behavior 留痕 (audit expert) — a durable, append-only record of one principal's work,
// metadata-only by default. Distinct from AuditLog (governance events). Feeds compliance + 周公. ──────

enum WorkSessionKind {
  CODING
  REVIEW
  AGENT_RUN
  CHAT
}

enum WorkOutcome {
  COMMITTED
  ABANDONED
  BLOCKED
  ERROR
  UNKNOWN
}

/// One principal's hara session, summarized. Metadata-only at T0 (paths hashed, no code bodies).
model WorkSession {
  id        String       @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  device    Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId  String
  person    Person?      @relation(fields: [personId], references: [id])
  personId  String? // authoritative — the device reports only what its bound identity did
  roleKey   String          @default("") // which digital-employee/persona was active

  kind      WorkSessionKind @default(CODING)
  repoHash  String          @default("") // sha256(remote||root) — never the path
  taskTitle String          @default("") // T1+ only; redacted via the guard
  toolCalls Json            @default("{}") // {edit:42, bash:11, agent:3}
  tasksCount         Int    @default(0)
  filesTouched       Int    @default(0)
  filePathsHashed    String[] @default([]) // sha256(path)[]
  approvalsRequested Int    @default(0)
  approvalsGranted   Int    @default(0)
  outcome   WorkOutcome     @default(UNKNOWN)
  commitShas String[]       @default([])

  model     String  @default("")
  tokensIn  Int     @default(0)
  tokensOut Int     @default(0)
  costUsd   Float? // reconciled from LiteLLM spend by deviceId (don't trust the client)
  latencyMs Int     @default(0)

  startedAt DateTime
  endedAt   DateTime?
  at        DateTime @default(now()) // received
  seq       Int // per-device monotonic — idempotent batch ingest
  prevHash  String   @default("") // tamper-evidence chain (per device)
  rowHash   String   @default("") // sha256(canonical(this) + prevHash)

  events WorkEvent[]

  @@unique([deviceId, seq]) // idempotent ingest
  @@index([orgId, at]) // compliance "who did what when"
  @@index([orgId, personId, startedAt]) // per-person timeline + 周公 feed
  @@index([orgId, repoHash])
}

/// Optional notable sub-event (denial / approval / guardrail trip / role switch). Append-only.
model WorkEvent {
  id        String      @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  session   WorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  type      String // "tool.denied" | "approval" | "guardrail.trip" | "role.switch"
  payload   Json        @default("{}") // redacted; labels mirror AssetVersion.redactions
  at        DateTime    @default(now())

  @@index([orgId, sessionId])
}
